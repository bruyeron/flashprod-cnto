# ── Sécurité ──────────────────────────────────────────────────────────────────
# Sel pour le hashage des mots de passe (chaîne aléatoire ≥ 32 caractères)
PASSWORD_SALT=changez_moi_par_une_chaine_aleatoire_longue

# Mot de passe du compte admin créé au premier démarrage
ADMIN_DEFAULT_PASS=Admin@1234!

# ── Source CSV distante (optionnel si vous utilisez l'upload local) ───────────
# URL publique ou privée d'un fichier CSV hébergé (Blob, S3, serveur...)
# BLOB_URL=https://votre-stockage.com/production.csv
# BLOB_READ_WRITE_TOKEN=token_si_acces_prive
